rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isLessonOwner() {
      return isSignedIn() && resource.data.coachId == request.auth.uid;
    }

    function isCreatingOwnLesson() {
      return isSignedIn() && request.resource.data.coachId == request.auth.uid;
    }

    function keepsLessonOwner() {
      return request.resource.data.coachId == resource.data.coachId;
    }

    // Users: authenticated users can manage user documents.
    match /users/{userId} {
      allow read, create, update, delete: if isSignedIn();
    }

    // Lessons: signed-in users can read the shared schedule.
    // Writes are limited to the lesson owner recorded in coachId.
    match /lessons/{lessonId} {
      allow read: if isSignedIn();
      allow create: if isCreatingOwnLesson();
      allow update: if isLessonOwner() && keepsLessonOwner();
      allow delete: if isLessonOwner();
    }

    // Coach Availability: authenticated users can manage availability documents.
    match /coachAvailability/{coachId} {
      allow read, create, update, delete: if isSignedIn();
    }

    // Email Queue: only signed-in users can create email jobs addressed to themselves.
    match /mail/{mailId} {
      allow create: if isSignedIn() &&
        request.resource.data.keys().hasOnly(['to', 'message', 'createdAt', 'type']) &&
        request.resource.data.to == request.auth.token.email &&
        request.resource.data.type == 'lesson-confirmation' &&
        request.resource.data.message.subject is string &&
        request.resource.data.message.text is string &&
        request.resource.data.message.html is string;
      allow read, update, delete: if false;
    }

    // Everything else stays closed by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
